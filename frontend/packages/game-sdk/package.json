{
  "name": "@airlinesim/game-sdk",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/game-sdk.cjs.js",
  "module": "./dist/game-sdk.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "default": "./src/index.ts",
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./api": {
      "default": "./src/api/index.ts",
      "import": "./src/api/index.ts",
      "types": "./src/api/index.ts"
    },
    "./auth": {
      "default": "./src/auth/index.ts",
      "import": "./src/auth/index.ts",
      "types": "./src/auth/index.ts"
    },
    "./config": {
      "default": "./src/config/index.ts",
      "import": "./src/config/index.ts",
      "types": "./src/config/index.ts"
    },
    "./contracts": {
      "default": "./src/contracts/index.ts",
      "import": "./src/contracts/index.ts",
      "types": "./src/contracts/index.ts"
    },
    "./errors": {
      "default": "./src/errors/index.ts",
      "import": "./src/errors/index.ts",
      "types": "./src/errors/index.ts"
    },
    "./realtime": {
      "default": "./src/realtime/index.ts",
      "import": "./src/realtime/index.ts",
      "types": "./src/realtime/index.ts"
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && vite build",
    "lint": "eslint . --max-warnings=0 && tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "test": "bun test"
  },
  "devDependencies": {
    "@airlinesim/eslint-config": "workspace:*",
    "eslint": "latest",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4"
  },
  "dependencies": {
    "@airlinesim/api-contracts": "workspace:*",
    "axios": "^1.15.2",
    "socket.io-client": "^4.8.1"
  }
}
