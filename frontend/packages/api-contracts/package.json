  },
  "dependencies": {
    "zod": "^4.2.0"
  },
  "devDependencies": {
    "@airlinesim/eslint-config": "workspace:*",
    "eslint": "latest",
    "typescript": "~6.0.2",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^4.5.4"
  }
}
