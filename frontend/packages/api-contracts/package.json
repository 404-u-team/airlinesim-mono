{
  "name": "@airlinesim/api-contracts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/api-contracts.cjs.js",
  "module": "./dist/api-contracts.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "default": "./src/index.ts",
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc --noEmit && vite build",
