{
  "name": "@airlinesim/air-ui",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./styles": "./src/styles/index.css"
  },
  "scripts": {
    "build": "vue-tsc -b && vite build",
    "dev": "storybook dev -p 6006",
    "lint": "eslint . --max-warnings=0 && vue-tsc --noEmit",
    "lint:fix": "eslint . --fix",
    "typecheck": "vue-tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@airlinesim/eslint-config": "workspace:*",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vue": "^3.5.32",
    "vue-tsc": "^3.2.6",
    "eslint": "latest",
    "storybook": "^10.4.0",
    "@storybook/vue3-vite": "^10.4.0"
  }
}
