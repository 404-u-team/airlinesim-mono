{
    "$schema": "https://turborepo.dev/schema.json",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**",
                "build/**"
            ]
        },
        "lint": {
            "dependsOn": [
                "^lint"
            ],
            "outputs": []
        },
        "lint:fix": {
            "cache": false,
            "dependsOn": [
                "^lint:fix"
            ],
            "outputs": []
        },
        "dev": {
            "cache": false,
            "persistent": true
        }
    }
}
