{
    "$schema": "https://turborepo.dev/schema.json",
    "globalEnv": [
        "VITE_BACKEND_URL",
        "VITE_BFF_URL",
        "VITE_SOCKET_URL",
        "VITE_MFE_BASE_URL"
    ],
    "tasks": {
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**",
                "build/**"
            ]
        },
        "lint": {
            "dependsOn": [
                "^lint"
            ],
            "outputs": []
        },
        "lint:fix": {
            "cache": false,
            "dependsOn": [
                "^lint:fix"
            ],
            "outputs": []
        },
        "test": {
            "dependsOn": [
                "^test"
            ],
            "outputs": []
        },
        "dev": {
            "cache": false,
            "persistent": true
        }
    }
}
