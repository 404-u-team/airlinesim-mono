{
  "name": "airlinesim",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "packageManager": "bun@1.3.1",
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "check": "turbo lint",
    "dev": "bun run generate:openapi && turbo dev --concurrency=14",
    "dev:fresh": "bun run ports:clear && bun run dev",
    "generate:openapi": "bun run --cwd packages/api-contracts generate",
    "lint": "turbo lint",
    "lint:fix": "turbo run lint:fix --continue=always --force",
    "ports:clear": "bun run scripts/clear-dev-ports.ts"
  },
  "private": true,
  "type": "module",
  "workspaces": [
    "bff",
    "packages/*",
    "apps/*"
  ],
  "dependencies": {
    "@module-federation/rsbuild-plugin": "^2.3.2",
    "turbo": "^2.9.6"
  }
}
