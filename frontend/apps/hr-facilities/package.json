{
  "name": "hr-facilities",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "rsbuild dev",
    "build": "vue-tsc -b && rsbuild build",
    "lint": "eslint . --max-warnings=0 && vue-tsc -b --noEmit",
    "lint:fix": "eslint . --fix",
    "preview": "rsbuild preview"
  },
  "dependencies": {
    "@airlinesim/air-ui": "workspace:*",
    "@airlinesim/api-contracts": "workspace:*",
    "@airlinesim/event-bus": "workspace:*",
    "@airlinesim/game-sdk": "workspace:*",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@airlinesim/eslint-config": "workspace:*",
    "@module-federation/rsbuild-plugin": "^2.3.2",
    "@rsbuild/core": "^1.7.1",
    "@rsbuild/plugin-vue": "^1.2.0",
    "@types/node": "^24.12.2",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "latest",
    "typescript": "~6.0.2",
    "vue-tsc": "^3.2.6"
  }
