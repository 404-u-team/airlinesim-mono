ARG BUN_VERSION=1.3.1

FROM oven/bun:${BUN_VERSION} AS bun

FROM node:22-bookworm-slim AS builder

COPY --from=bun /usr/local/bin/bun /usr/local/bin/bun
RUN ln -s /usr/local/bin/bun /usr/local/bin/bunx

WORKDIR /app

COPY . .

ARG VITE_BACKEND_URL=/bff
ARG VITE_BFF_URL=/bff
ARG VITE_SOCKET_URL=https://api.master.stand.airlinesim.ms0ur.dev/
ARG VITE_MFE_BASE_URL=http://localhost:4100

ENV NODE_ENV=production
ENV VITE_DEV_PORT_BASE=4100
ENV VITE_BACKEND_URL=${VITE_BACKEND_URL}
ENV VITE_BFF_URL=${VITE_BFF_URL}
ENV VITE_SOCKET_URL=${VITE_SOCKET_URL}
ENV VITE_MFE_BASE_URL=${VITE_MFE_BASE_URL}
ENV TURBO_TELEMETRY_DISABLED=1

RUN bun install --frozen-lockfile
RUN bun run generate:bff-openapi && bun run generate:openapi
RUN bun run turbo run build

FROM nginx:1.27-alpine

COPY docker/nginx-single.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/apps/shell/dist /usr/share/nginx/apps/shell
COPY --from=builder /app/apps/map/dist /usr/share/nginx/apps/map
COPY --from=builder /app/apps/fleet-ops/dist /usr/share/nginx/apps/fleet-ops
COPY --from=builder /app/apps/finance-stock/dist /usr/share/nginx/apps/finance-stock
COPY --from=builder /app/apps/network-planner/dist /usr/share/nginx/apps/network-planner
COPY --from=builder /app/apps/events-news/dist /usr/share/nginx/apps/events-news
COPY --from=builder /app/apps/hr-facilities/dist /usr/share/nginx/apps/hr-facilities

EXPOSE 80
