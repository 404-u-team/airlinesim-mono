# HTTP API gateway address used by @airlinesim/game-sdk. Frontend calls BFF;
# BFF calls the backend configured by BFF_BACKEND_BASE_URL.
VITE_BACKEND_URL=/bff
VITE_BFF_URL=/bff

# Realtime/socket gateway address. Leave equal to VITE_BACKEND_URL unless sockets
# are served from a different host.
VITE_SOCKET_URL=https://api.master.stand.airlinesim.ms0ur.dev/

# Optional production MFE origin. When set, shell loads remote manifests from
# ${VITE_MFE_BASE_URL}/mfe/<app>/mf-manifest.json and remotes publish chunks
# under the same /mfe/<app>/ prefix. Leave empty for multi-port dev mode.
# Docker compose builds API calls against /bff so auth stays same-origin.
VITE_MFE_BASE_URL=

# First frontend dev port. Apps use consecutive ports:
# shell=base, map=base+1, fleet=base+2, finance=base+3,
# network=base+4, events=base+5, hr=base+6.
VITE_DEV_PORT_BASE=4100

# Bun BFF settings.
BFF_PORT=4200
BFF_BACKEND_BASE_URL=https://api.master.stand.airlinesim.ms0ur.dev/

# Backend admin credentials used by BFF service operations, including
# world-data import. The BFF does not forward user tokens for these mutations;
# it logs in with this backend admin account and caches the access token in memory.
BACKEND_ADMIN_LOGIN=admin
BACKEND_ADMIN_PASSWORD=change-me
