# kafka
KAFKA_BROKERS=kafka:29092

# operations-db configs
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=db
POSTGRES_HOST=operations-db

# Postgres log level for this service's DB client
# Possible values: trace, debug, info, warn, error, fatal
# Use `info` for production-like logs, `debug` or `trace` for development
DB_LOG_LEVEL=info

# some game configs
START_FUEL_PRICE=100